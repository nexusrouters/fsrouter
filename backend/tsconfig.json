{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmitOnError": false,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "open-sse": ["./open-sse"],
      "open-sse/*": ["./open-sse/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist", "open-sse", "open-sse/**/*", "open-sse/**/*.js", "open-sse/**/*.ts", "**/open-sse/**/*", "**/open-sse", "src/routes/auth/oidc/**/*"]
}
