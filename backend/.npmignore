# Exclude source code if we want, or keep it. Let's exclude python venv and dev tools
.venv/
**/__pycache__/
*.tsbuildinfo
tsconfig.json
.env
.env.*
node_modules/
src/automation/profiles/

# Explicitly include dist folder (compiled server code) to prevent npm from ignoring it due to parent .gitignore
!dist/
!dist/**/*
